# ─────────────────────────────────────────────────────────────────────────────
# MEXC Trading Bot — environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env && nano .env
#
# NEVER commit .env to git — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── MEXC Exchange API ─────────────────────────────────────────────────────────
# Create at: https://www.mexc.com/user/openapi
# Required permissions: Read + Trade (spot). Do NOT enable Withdraw.
MEXC_API_KEY=
MEXC_SECRET=

# ── Coinranking (dynamic coin selection) ─────────────────────────────────────
# Free tier works; Professional tier unlocks better rate limits + history.
# Get key at: https://coinranking.com/api
COINRANKING_API_KEY=

# ── Telegram alerts ───────────────────────────────────────────────────────────
# BotFather: https://t.me/BotFather  → /newbot
# Chat ID:   send a message to your bot, then:
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Claude AI gate (optional) ─────────────────────────────────────────────────
# Only needed when USE_CLAUDE_GATE=True in config.py.
# Currently disabled — leave blank unless you re-enable the gate.
# ANTHROPIC_API_KEY=
